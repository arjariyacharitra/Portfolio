# ─────────────────────────────────────────────
# Portfolio Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────

# Server
PORT=5000

# CORS — your deployed frontend URL (or http://localhost:5173 for local dev)
FRONTEND_URL=http://localhost:5173

# ─── Email (Nodemailer via Gmail SMTP) ───────
# Use a Gmail account with an App Password (not your regular password).
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password

# The email address that RECEIVES contact form submissions
OWNER_EMAIL=your-gmail@gmail.com

# The "From" display name shown in the email client
FROM_NAME=Portfolio Contact Form
